      "source": [
        "from torchvision.models import ResNet18_Weights\n",
        "\n",
        "logo_model = models.resnet18(weights=ResNet18_Weights.DEFAULT)\n",
        "logo_model.fc = nn.Linear(logo_model.fc.in_features, len(logo_classes))\n",
        "logo_model.to(device)\n",
        "\n",
        "criterion = nn.CrossEntropyLoss()\n",
        "optimizer = optim.Adam(logo_model.parameters(), lr=0.0001)\n",
        "scheduler = optim.lr_scheduler.StepLR(optimizer, step_size=3, gamma=0.1)\n",
        "\n",
        "epochs = 5\n",
        "for epoch in range(epochs):\n",
        "    logo_model.train()\n",
        "    running_loss = 0.0\n",
        "    for inputs, labels in brand_loader:\n",
        "        inputs, labels = inputs.to(device), labels.to(device)\n",
        "        optimizer.zero_grad()\n",
        "        outputs = logo_model(inputs)\n",
        "        loss = criterion(outputs, labels)\n",
        "        loss.backward()\n",
        "        optimizer.step()\n",
        "        running_loss += loss.item()\n",
        "\n",
        "    scheduler.step()\n",
        "    print(f\"Epoch {epoch+1}/{epochs} - Brand Loss: {running_loss/len(brand_loader):.4f} | LR: {scheduler.get_last_lr()[0]}\")\n",
        "\n",
        "torch.save(logo_model.state_dict(), 'car_logo_model_optimized.pth')"
      ]
    },

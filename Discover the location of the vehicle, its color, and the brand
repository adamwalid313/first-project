      "source": [
        "transform = transforms.Compose([\n",
        "    transforms.Resize((224, 224)),\n",
        "    transforms.ToTensor(),\n",
        "    transforms.Normalize([0.485, 0.456, 0.406], [0.229, 0.224, 0.225])\n",
        "])\n",
        "\n",
        "brand_dataset = datasets.ImageFolder('/content/brand_data/Car_Brand_Logos/Train', transform=transform)\n",
        "color_dataset = datasets.ImageFolder('/content/color_data/train', transform=transform)\n",
        "\n",
        "brand_loader = DataLoader(brand_dataset, batch_size=32, shuffle=True)\n",
        "color_loader = DataLoader(color_dataset, batch_size=32, shuffle=True)\n",
        "\n",
        "logo_classes = brand_dataset.classes\n",
        "color_classes = color_dataset.classes"
      ]
    },
    {
      "cell_type": "code",
      "execution_count": null,
      "metadata": {
        "id": "RfD_Tg9jkYf4"
      },
      "outputs": [],
      "source": [
        "train_transform = transforms.Compose([\n",
        "    transforms.Resize((224, 224)),\n",
        "    transforms.RandomHorizontalFlip(),\n",
        "    transforms.RandomRotation(15),\n",
        "    transforms.ColorJitter(brightness=0.2, contrast=0.2),\n",
        "    transforms.ToTensor(),\n",
        "    transforms.Normalize([0.485, 0.456, 0.406], [0.229, 0.224, 0.225])\n",
        "])\n",
        "\n",
        "test_transform = transforms.Compose([\n",
        "    transforms.Resize((224, 224)),\n",
        "    transforms.ToTensor(),\n",
        "    transforms.Normalize([0.485, 0.456, 0.406], [0.229, 0.224, 0.225])\n",
        "])\n",
        "\n",
        "brand_dataset = datasets.ImageFolder('/content/brand_data/Car_Brand_Logos/Train', transform=train_transform)\n",
        "color_dataset = datasets.ImageFolder('/content/color_data/train', transform=train_transform)\n",
        "\n",
        "brand_loader = DataLoader(brand_dataset, batch_size=32, shuffle=True)\n",
        "color_loader = DataLoader(color_dataset, batch_size=32, shuffle=True)\n",
        "\n",
        "logo_classes = brand_dataset.classes\n",
        "color_classes = color_dataset.classes"
      ]
    },

        "import os\n",
        "import torch\n",
        "import torch.nn as nn\n",
        "import torch.optim as optim\n",
        "from torchvision import models, transforms, datasets\n",
        "from torch.utils.data import DataLoader\n",
        "\n",
        "\n",
        "!kaggle datasets download -d volkandl/car-brand-logos --force\n",
        "!kaggle datasets download -d landrykezebou/vcor-vehicle-color-recognition-dataset --force\n",
        "!unzip -q car-brand-logos.zip -d /content/brand_data\n",
        "!unzip -q vcor-vehicle-color-recognition-dataset.zip -d /content/color_data\n",
        "\n",
        "device = torch.device(\"cuda\" if torch.cuda.is_available() else \"cpu\")"
      ]
    },

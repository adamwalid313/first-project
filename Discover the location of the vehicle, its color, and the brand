        "from google.colab import files\n",
        "import pandas as pd\n",
        "from datetime import datetime\n",
        "import io\n",
        "import cv2\n",
        "from PIL import Image\n",
        "from google.colab.patches import cv2_imshow\n",
        "import numpy as np\n",
        "from ultralytics import YOLO\n",
        "import torch\n",
        "\n",
        "yolo_main = YOLO('yolov8n.pt')\n",
        "\n",
        "uploaded = files.upload()\n",
        "\n",
        "def run_auto_dashboard(uploaded_files):\n",
        "    inventory_data = []\n",
        "\n",
        "    for i, (filename, content) in enumerate(uploaded_files.items()):\n",
        "        nparr = np.frombuffer(content, np.uint8)\n",
        "        img = cv2.imdecode(nparr, cv2.IMREAD_COLOR)\n",
        "        if img is None: continue\n",
        "\n",
        "        results = yolo_main(img, verbose=False)\n",
        "        brand, color = \"N/A\", \"N/A\"\n",
        "        status = \"N/A\"\n",
        "\n",
        "        max_area = 0\n",
        "        best_box = None\n",
        "\n",
        "        for r in results:\n",
        "            for box in r.boxes:\n",
        "                if int(box.cls) in [2, 5, 7]:\n",
        "                    coords = map(int, box.xyxy[0])\n",
        "                    x1, y1, x2, y2 = coords\n",
        "                    area = (x2 - x1) * (y2 - y1)\n",
        "\n",
        "                    if area > max_area:\n",
        "                        max_area = area\n",
        "                        best_box = (x1, y1, x2, y2)\n",
        "\n",
        "        if best_box:\n",
        "            x1, y1, x2, y2 = best_box\n",
        "            car_roi = img[y1:y2, x1:x2]\n",
        "\n",
        "            try:\n",
        "                h, w = car_roi.shape[:2]\n",
        "                front_crop = car_roi[int(h*0.25):int(h*0.75), int(w*0.15):int(w*0.85)]\n",
        "\n",
        "                pil_img = Image.fromarray(cv2.cvtColor(front_crop, cv2.COLOR_BGR2RGB))\n",
        "                batch = transform(pil_img).unsqueeze(0).to(device)\n",
        "\n",
        "                logo_model.eval()\n",
        "                color_model.eval()\n",
        "                with torch.no_grad():\n",
        "                    l_idx = torch.max(logo_model(batch), 1)[1].item()\n",
        "                    c_idx = torch.max(color_model(batch), 1)[1].item()\n",
        "                    brand = logo_classes[l_idx]\n",
        "                    color = color_classes[c_idx]\n",
        "            except:\n",
        "                pass\n",
        "\n",
        "            status = \"WASHING 🧼\" if i % 2 != 0 else \"WAITING ⏳\"\n",
        "            box_color = (255, 165, 0) if \"WASHING\" in status else (0, 255, 0)\n",
        "\n",
        "            cv2.rectangle(img, (x1, y1), (x2, y2), box_color, 4)\n",
        "            cv2.putText(img, f\"{brand} | {color}\", (x1, y1-15), 0, 0.9, box_color, 3)\n",
        "\n",
        "        inventory_data.append({\n",
        "            \"Entry Order\": i + 1,\n",
        "            \"Vehicle\": brand,\n",
        "            \"Color\": color,\n",
        "            \"Status\": status if best_box else \"No Vehicle\",\n",
        "            \"Time In\": datetime.now().strftime(\"%H:%M\")\n",
        "        })\n",
        "\n",
        "        print(f\"File: {filename}\")\n",
        "        cv2_imshow(img)\n",
        "        print(\"-\" * 30)\n",
        "\n",
        "    df = pd.DataFrame(inventory_data)\n",
        "    display(df)\n",
        "\n",
        "run_auto_dashboard(uploaded)"
      ]

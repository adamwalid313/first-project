        "from torchvision.models import ResNet34_Weights\n",
        "\n",
        "color_model = models.resnet34(weights=ResNet34_Weights.DEFAULT)\n",
        "color_model.fc = nn.Linear(color_model.fc.in_features, len(color_classes))\n",
        "color_model.to(device)\n",
        "\n",
        "optimizer_color = optim.Adam(color_model.parameters(), lr=0.0001)\n",
        "scheduler_color = optim.lr_scheduler.StepLR(optimizer_color, step_size=3, gamma=0.1)\n",
        "\n",
        "for epoch in range(epochs):\n",
        "    color_model.train()\n",
        "    running_loss = 0.0\n",
        "    for inputs, labels in color_loader:\n",
        "        inputs, labels = inputs.to(device), labels.to(device)\n",
        "        optimizer_color.zero_grad()\n",
        "        outputs = color_model(inputs)\n",
        "        loss = criterion(outputs, labels)\n",
        "        loss.backward()\n",
        "        optimizer_color.step()\n",
        "        running_loss += loss.item()\n",
        "\n",
        "    scheduler_color.step()\n",
        "    print(f\"Epoch {epoch+1}/{epochs} - Color Loss: {running_loss/len(color_loader):.4f}\")\n",
        "\n",
        "torch.save(color_model.state_dict(), 'vcor_resnet34.pth')"
      ]
